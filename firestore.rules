rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'revanthsai3567@gmail.com' ||
        request.auth.token.email == 'ayman.saleem07@gmail.com' ||
        request.auth.uid == 'njVejWBbspQgvkeQKUlkpmUo7sy2'
      );
    }

    function isValidProduct(data) {
      return data.keys().hasAll([
        'name',
        'price',
        'description',
        'imageUrl',
        'productLink',
        'category',
        'createdAt',
        'updatedAt'
      ])
      && data.name is string && data.name.size() <= 200
      && data.price is string && data.price.size() <= 50
      && data.description is string && data.description.size() <= 2000
      && data.imageUrl is string && data.imageUrl.size() <= 1000
      && data.productLink is string && data.productLink.size() <= 1000
      && data.category is string && data.category.size() <= 100
      && data.createdAt is number
      && data.updatedAt is number;
    }

    // ---------- Products ----------
    match /products/{productId} {

      // Anyone can read products
      allow read: if true;

      // Only admin can create, with valid structure
      allow create: if isAdmin()
        && isValidProduct(request.resource.data);

      // Only admin can update, and cannot change createdAt
      allow update: if isAdmin()
        && isValidProduct(request.resource.data)
        && request.resource.data.createdAt == resource.data.createdAt;

      // Only admin can delete
      allow delete: if isAdmin();
    }

    // ---------- Default deny ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}