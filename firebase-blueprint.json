{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product available for sale",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the product" },
        "price": { "type": "string", "description": "The current displayed price" },
        "originalPrice": { "type": "string", "description": "The original M.R.P price" },
        "salePrice": { "type": "string", "description": "The sale price if applicable" },
        "description": { "type": "string", "description": "Detailed product description" },
        "imageUrl": { "type": "string", "description": "URL to the product image" },
        "productLink": { "type": "string", "description": "Redirect link to the actual product page" },
        "category": { "type": "string", "description": "Product category" },
        "createdAt": { "type": "number", "description": "Timestamp when created" },
        "updatedAt": { "type": "number", "description": "Timestamp when last updated" }
      },
      "required": ["name", "price", "description", "imageUrl", "productLink", "category", "createdAt", "updatedAt"]
    },
    "Admin": {
      "title": "Admin",
      "description": "User with administrative privileges",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["email", "uid"]
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": "Product",
      "description": "Collection of all products"
    },
    "admins/{adminId}": {
      "schema": "Admin",
      "description": "Collection of authorized administrators"
    }
  }
}
